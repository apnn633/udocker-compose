#!/usr/bin/env python3
"""udocker-compose — A Docker Compose compatible orchestration tool for udocker

Features:
  - Parse docker-compose.yml (v2/v3)
  - Topological sorting of service dependencies and ordered startup
  - Simulated Docker networking (service name resolution via /etc/hosts injection)
  - Named volume management (mapped to local directories)
  - Process lifecycle management with automatic restart
  - Health checks
  - Log management

Usage:
  udocker-compose up [-d] [--no-recreate] [service...]
  udocker-compose down [-v]
  udocker-compose ps
  udocker-compose pull [service...]
  udocker-compose logs [-f] [-n N] [service...]
  udocker-compose restart [service...]
  udocker-compose stop [service...]
  udocker-compose start [service...]
  udocker-compose exec service command [args...]
  udocker-compose config
  udocker-compose run [--rm] service command [args...]
"""

import argparse
import hashlib
import json
import os
import signal
import subprocess
import sys
import textwrap
import time
from collections import defaultdict
from pathlib import Path

try:
    import yaml
except ImportError:
    print("Error: PyYAML is required. Please run: pip install pyyaml", file=sys.stderr)
    sys.exit(1)

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
COMPOSE_FILES = ["docker-compose.yml", "docker-compose.yaml", "compose.yml", "compose.yaml"]
STATE_DIR_NAME = ".udocker-compose"
UDOCKER_BIN = os.environ.get("UDOCKER_COMPOSE_UDOCKER", "udocker")
EXEC_MODE = os.environ.get("UDOCKER_COMPOSE_EXECMODE", "P1")

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

def log_info(msg):
    print(f"\033[32m[+]\033[0m {msg}")

def log_warn(msg):
    print(f"\033[33m[!]\033[0m {msg}", file=sys.stderr)

def log_error(msg):
    print(f"\033[31m[-]\033[0m {msg}", file=sys.stderr)

def log_debug(msg):
    if os.environ.get("UDOCKER_COMPOSE_DEBUG"):
        print(f"\033[36m[D]\033[0m {msg}", file=sys.stderr)

def run_cmd(cmd, check=True, capture=False, **kwargs):
    """Execute a shell command"""
    log_debug(f"exec: {cmd if isinstance(cmd, str) else ' '.join(cmd)}")
    stdout = subprocess.PIPE if capture else None
    stderr = subprocess.PIPE if capture else None
    r = subprocess.run(cmd, shell=isinstance(cmd, str), check=check,
                       stdout=stdout, stderr=stderr, text=True, **kwargs)
    return r

def udocker(*args, check=True, capture=False):
    """Call a udocker command"""
    cmd = [UDOCKER_BIN] + list(args)
    return run_cmd(cmd, check=check, capture=capture)

def find_compose_file(directory="."):
    """Find a compose file"""
    for name in COMPOSE_FILES:
        p = Path(directory) / name
        if p.exists():
            return p
    return None

# ---------------------------------------------------------------------------
# YAML parsing and normalization
# ---------------------------------------------------------------------------

class ComposeConfig:
    """Parse and normalize docker-compose.yml"""

    def __init__(self, filepath, project_name=None):
        self.filepath = Path(filepath).resolve()
        self.project_dir = self.filepath.parent
        self.project_name = project_name or self.project_dir.name
        # Normalize project name: keep only alphanumeric characters and hyphens
        self.project_name = "".join(
            c if c.isalnum() or c in "-_" else "" for c in self.project_name
        ).lower()

        with open(self.filepath) as f:
            self.raw = yaml.safe_load(f)

        self.services = {}
        self.networks = {}
        self.volumes = {}
        self._parse()

    def _parse(self):
        raw_services = self.raw.get("services", {})
        if not raw_services:
            raise ValueError("No services definition found in compose file")

        self.networks = self.raw.get("networks", {})
        self.volumes = self.raw.get("volumes", {})

        for name, svc_def in raw_services.items():
            self.services[name] = self._normalize_service(name, svc_def)

    def _normalize_service(self, name, svc):
        """Normalize a compose service definition into internal format"""
        normalized = {
            "name": name,
            "container_name": svc.get("container_name", f"{self.project_name}_{name}"),
            "image": svc.get("image"),
            "build": svc.get("build"),
            "command": self._normalize_command(svc.get("command")),
            "entrypoint": self._normalize_command(svc.get("entrypoint")),
            "environment": self._normalize_env(svc.get("environment")),
            "env_file": self._normalize_list(svc.get("env_file")),
            "volumes": self._normalize_volumes(svc.get("volumes", [])),
            "ports": self._normalize_ports(svc.get("ports", [])),
            "depends_on": self._normalize_depends(svc.get("depends_on")),
            "networks": self._normalize_list(svc.get("networks")) or list(self.networks.keys()) or ["default"],
            "restart": svc.get("restart", "no"),
            "user": svc.get("user"),
            "working_dir": svc.get("working_dir"),
            "hostname": svc.get("hostname", name),
            "healthcheck": svc.get("healthcheck"),
            "shm_size": svc.get("shm_size"),
            "extra_hosts": self._normalize_list(svc.get("extra_hosts")),
            "dns": self._normalize_list(svc.get("dns")),
            "tmpfs": self._normalize_list(svc.get("tmpfs")),
            "privileged": svc.get("privileged", False),
            "devices": self._normalize_list(svc.get("devices")),
            "cap_add": self._normalize_list(svc.get("cap_add")),
        }

        # Error if neither image nor build is specified
        if not normalized["image"] and not normalized["build"]:
            raise ValueError(f"Service '{name}' must specify either image or build")

        # If build is specified but no image, generate an image name
        if normalized["build"] and not normalized["image"]:
            normalized["image"] = f"{self.project_name}_{name}:latest"

        return normalized

    def _normalize_command(self, cmd):
        if cmd is None:
            return None
        if isinstance(cmd, list):
            return cmd
        return cmd  # String form, keep as-is

    def _normalize_env(self, env):
        """Normalize environment variables into a dict"""
        if env is None:
            return {}
        if isinstance(env, dict):
            return {k: str(v) for k, v in env.items()}
        if isinstance(env, list):
            result = {}
            for item in env:
                if "=" in item:
                    k, v = item.split("=", 1)
                    result[k] = v
                else:
                    result[item] = os.environ.get(item, "")
            return result
        return {}

    def _normalize_list(self, val):
        if val is None:
            return []
        if isinstance(val, str):
            return [val]
        return list(val)

    def _normalize_volumes(self, vols):
        """Normalize volumes into a [{host, container, mode}] list"""
        result = []
        for v in vols:
            if isinstance(v, str):
                parts = v.split(":")
                if len(parts) == 1:
                    result.append({"host": None, "container": parts[0], "mode": "rw"})
                elif len(parts) == 2:
                    result.append({"host": parts[0], "container": parts[1], "mode": "rw"})
                else:
                    result.append({"host": parts[0], "container": parts[1], "mode": parts[2]})
            elif isinstance(v, dict):
                result.append({
                    "host": v.get("source"),
                    "container": v.get("target"),
                    "mode": "ro" if v.get("read_only") else "rw",
                })
        return result

    def _normalize_ports(self, ports):
        """Normalize port mappings into [{host_port, container_port, protocol}]"""
        result = []
        for p in ports:
            if isinstance(p, (int, float)):
                result.append({"host": str(int(p)), "container": str(int(p)), "protocol": "tcp"})
            elif isinstance(p, str):
                # "8000:8000", "8000:8000/udp", "127.0.0.1:8000:8000"
                proto = "tcp"
                if "/" in p:
                    p, proto = p.rsplit("/", 1)
                parts = p.split(":")
                if len(parts) == 1:
                    result.append({"host": parts[0], "container": parts[0], "protocol": proto})
                elif len(parts) == 2:
                    result.append({"host": parts[0], "container": parts[1], "protocol": proto})
                elif len(parts) == 3:
                    # host_ip:host_port:container_port — ignore host_ip
                    result.append({"host": parts[1], "container": parts[2], "protocol": proto})
            elif isinstance(p, dict):
                result.append({
                    "host": str(p.get("published", p.get("target"))),
                    "container": str(p.get("target")),
                    "protocol": p.get("protocol", "tcp"),
                })
        return result

    def _normalize_depends(self, deps):
        """Normalize depends_on"""
        if deps is None:
            return []
        if isinstance(deps, list):
            return deps
        if isinstance(deps, dict):
            # v2/v3 with condition
            return list(deps.keys())
        return []

    def get_service_names(self):
        return list(self.services.keys())

    def get_startup_order(self):
        """Topological sort, returns service names ordered by dependencies"""
        graph = defaultdict(set)
        in_degree = defaultdict(int)
        all_services = set(self.services.keys())

        for name, svc in self.services.items():
            in_degree.setdefault(name, 0)
            for dep in svc["depends_on"]:
                if dep not in all_services:
                    raise ValueError(f"Service '{name}' depends on non-existent service '{dep}'")
                graph[dep].add(name)
                in_degree[name] += 1

        queue = [s for s in all_services if in_degree[s] == 0]
        order = []
        while queue:
            queue.sort()  # Stable sort
            node = queue.pop(0)
            order.append(node)
            for neighbor in sorted(graph[node]):
                in_degree[neighbor] -= 1
                if in_degree[neighbor] == 0:
                    queue.append(neighbor)

        if len(order) != len(all_services):
            raise ValueError("Circular dependency detected!")

        return order


# ---------------------------------------------------------------------------
# State management
# ---------------------------------------------------------------------------

class StateManager:
    """Manage runtime state in the .udocker-compose/ directory"""

    def __init__(self, project_dir, project_name):
        self.base = Path(project_dir) / STATE_DIR_NAME
        self.project_name = project_name
        self.pids_dir = self.base / "pids"
        self.logs_dir = self.base / "logs"
        self.volumes_dir = self.base / "volumes"
        self.network_dir = self.base / "network"
        self.state_file = self.base / "state.json"

    def init(self):
        """Create directory structure"""
        for d in [self.pids_dir, self.logs_dir, self.volumes_dir, self.network_dir]:
            d.mkdir(parents=True, exist_ok=True)
        if not self.state_file.exists():
            self._save_state({})

    def _load_state(self):
        try:
            return json.loads(self.state_file.read_text())
        except (json.JSONDecodeError, FileNotFoundError):
            return {}

    def _save_state(self, state):
        self.state_file.write_text(json.dumps(state, indent=2, ensure_ascii=False))

    def set_service_state(self, name, **kwargs):
        state = self._load_state()
        if name not in state:
            state[name] = {}
        state[name].update(kwargs)
        self._save_state(state)

    def get_service_state(self, name):
        return self._load_state().get(name, {})

    def remove_service_state(self, name):
        state = self._load_state()
        state.pop(name, None)
        self._save_state(state)

    def get_all_states(self):
        return self._load_state()

    def save_pid(self, service_name, pid):
        (self.pids_dir / f"{service_name}.pid").write_text(str(pid))

    def get_pid(self, service_name):
        pidfile = self.pids_dir / f"{service_name}.pid"
        if pidfile.exists():
            try:
                pid = int(pidfile.read_text().strip())
                # Check if the process is alive
                os.kill(pid, 0)
                return pid
            except (ValueError, ProcessLookupError, PermissionError):
                pidfile.unlink(missing_ok=True)
        return None

    def clear_pid(self, service_name):
        (self.pids_dir / f"{service_name}.pid").unlink(missing_ok=True)

    def get_log_path(self, service_name):
        return self.logs_dir / f"{service_name}.log"

    def get_volume_path(self, volume_name):
        return self.volumes_dir / volume_name

    def get_hosts_file(self):
        return self.network_dir / "hosts"


# ---------------------------------------------------------------------------
# Network management — Simulated Docker networking
# ---------------------------------------------------------------------------

class NetworkManager:
    """Simulate Docker networking via /etc/hosts injection and bind mounts

    Principle:
      In Docker, containers on the same network can access each other by service name.
      In udocker, all containers share the host network stack, so:
      1. Generate a hosts file mapping all service names to 127.0.0.1
      2. Bind-mount that hosts file into each container's /etc/hosts
      3. Services communicate via localhost + their respective ports
    """

    def __init__(self, state: StateManager, config: ComposeConfig):
        self.state = state
        self.config = config

    def generate_hosts_file(self):
        """Generate an /etc/hosts file with all service name mappings"""
        hosts_path = self.state.get_hosts_file()
        lines = [
            "# Generated by udocker-compose — Simulated Docker networking",
            "127.0.0.1\tlocalhost",
            "::1\tlocalhost ip6-localhost ip6-loopback",
        ]

        # Add hostname and service name mappings for each service
        service_names = set()
        for name, svc in self.config.services.items():
            service_names.add(name)
            service_names.add(svc["container_name"])
            service_names.add(svc["hostname"])

        # Map all service names -> 127.0.0.1
        names_str = "\t".join(sorted(service_names))
        lines.append(f"127.0.0.1\t{names_str}")

        # Add extra_hosts
        for name, svc in self.config.services.items():
            for host_entry in svc.get("extra_hosts", []):
                if ":" in host_entry:
                    hostname, ip = host_entry.split(":", 1)
                    lines.append(f"{ip.strip()}\t{hostname.strip()}")

        hosts_path.write_text("\n".join(lines) + "\n")
        log_info(f"Network: generated hosts file ({len(service_names)} service names)")
        return hosts_path

    def inject_hosts_to_container(self, container_name):
        """Get the container rootfs path and copy the hosts file (fallback when -v mount is unreliable)"""
        try:
            r = udocker("inspect", "-p", container_name, capture=True, check=False)
            if r.returncode == 0 and r.stdout.strip():
                rootfs = Path(r.stdout.strip())
                etc_hosts = rootfs / "etc" / "hosts"
                if etc_hosts.parent.exists():
                    hosts_content = self.state.get_hosts_file().read_text()
                    etc_hosts.write_text(hosts_content)
                    log_debug(f"Injected hosts into {etc_hosts}")
                    return True
        except Exception as e:
            log_debug(f"hosts injection failed: {e}")
        return False

    def get_run_args(self):
        """Return network-related arguments for udocker run"""
        hosts_path = self.state.get_hosts_file()
        if hosts_path.exists():
            return ["-v", f"{hosts_path}:/etc/hosts"]
        return []


# ---------------------------------------------------------------------------
# Volume management
# ---------------------------------------------------------------------------

class VolumeManager:
    """Manage named volumes — mapped to local directories"""

    def __init__(self, state: StateManager, config: ComposeConfig):
        self.state = state
        self.config = config

    def ensure_volumes(self):
        """Create local directories for all named volumes"""
        for vol_name in self.config.volumes:
            vol_path = self.state.get_volume_path(vol_name)
            vol_path.mkdir(parents=True, exist_ok=True)
            log_debug(f"Volume '{vol_name}' -> {vol_path}")

    def resolve_volume_path(self, host_path, service_name):
        """Resolve volume path: named volume -> local directory, relative path -> absolute path"""
        if host_path is None:
            return None

        # Named volume
        if not host_path.startswith("/") and not host_path.startswith(".") and not host_path.startswith("~"):
            if host_path in self.config.volumes or host_path.replace("-", "_") in self.config.volumes:
                vol_path = self.state.get_volume_path(host_path)
                vol_path.mkdir(parents=True, exist_ok=True)
                return str(vol_path)

        # Relative path -> absolute path
        if host_path.startswith("."):
            return str(self.config.project_dir / host_path)

        # ~ expansion
        if host_path.startswith("~"):
            return str(Path(host_path).expanduser())

        return host_path

    def get_run_args(self, service_name):
        """Return the -v arguments for a service"""
        svc = self.config.services[service_name]
        args = []
        for vol in svc["volumes"]:
            host = self.resolve_volume_path(vol["host"], service_name)
            container = vol["container"]
            if host:
                # Ensure host directory exists
                host_path = Path(host)
                if not host_path.exists():
                    host_path.mkdir(parents=True, exist_ok=True)
                    log_debug(f"Created mount directory: {host}")
                args.extend(["-v", f"{host}:{container}"])
        return args


# ---------------------------------------------------------------------------
# Service manager
# ---------------------------------------------------------------------------

class ServiceManager:
    """Manage the full lifecycle of a single service"""

    def __init__(self, config: ComposeConfig, state: StateManager,
                 network: NetworkManager, volumes: VolumeManager):
        self.config = config
        self.state = state
        self.network = network
        self.volumes = volumes

    def pull(self, service_name):
        """Pull a service image"""
        svc = self.config.services[service_name]
        image = svc["image"]

        if svc["build"] and not svc.get("image"):
            log_warn(f"Service '{service_name}' uses build, which udocker does not support. Please build elsewhere then save/load")
            return False

        log_info(f"Pulling image: {image}")
        r = udocker("pull", image, check=False)
        if r.returncode != 0:
            log_error(f"Failed to pull {image}")
            return False
        return True

    def create(self, service_name, force=False):
        """Create a container"""
        svc = self.config.services[service_name]
        container_name = svc["container_name"]
        image = svc["image"]

        # Check if container already exists
        r = udocker("inspect", container_name, check=False, capture=True)
        if r.returncode == 0 and not force:
            log_info(f"Container '{container_name}' already exists, skipping creation")
            return True

        if r.returncode == 0 and force:
            log_info(f"Removing old container '{container_name}'")
            udocker("rm", "-f", container_name, check=False)

        log_info(f"Creating container: {container_name} <- {image}")
        r = udocker("create", f"--name={container_name}", image, check=False)
        if r.returncode != 0:
            log_error(f"Failed to create container '{container_name}'")
            return False

        # Set execution mode
        udocker("setup", f"--execmode={EXEC_MODE}", container_name, check=False)

        # Inject hosts file into container rootfs
        self.network.inject_hosts_to_container(container_name)

        self.state.set_service_state(service_name,
                                     container_name=container_name,
                                     image=image,
                                     created=True)
        return True

    def _build_run_args(self, service_name, extra_args=None):
        """Build the full argument list for udocker run"""
        svc = self.config.services[service_name]
        container_name = svc["container_name"]
        args = []

        # Environment variables
        for key, val in svc["environment"].items():
            args.extend(["-e", f"{key}={val}"])

        # env_file
        for ef in svc["env_file"]:
            ef_path = self.config.project_dir / ef
            if ef_path.exists():
                args.extend(["--env-file", str(ef_path)])
            else:
                log_warn(f"env_file not found: {ef}")

        # Volume mounts
        args.extend(self.volumes.get_run_args(service_name))

        # Network (hosts file mount)
        args.extend(self.network.get_run_args())

        # Port mapping (Pn mode only)
        if EXEC_MODE.startswith("P"):
            for port in svc["ports"]:
                args.extend(["--publish", f"{port['host']}:{port['container']}"])

        # Working directory
        if svc["working_dir"]:
            args.extend(["-w", svc["working_dir"]])

        # User
        if svc["user"]:
            args.extend(["--user", str(svc["user"])])

        # Hostname (passed via environment variable, hostname command may not be reliable under PRoot)
        args.extend(["-e", f"HOSTNAME={svc['hostname']}"])

        # entrypoint
        if svc["entrypoint"] is not None:
            if isinstance(svc["entrypoint"], list):
                args.extend(["--entrypoint", svc["entrypoint"][0]])
            elif isinstance(svc["entrypoint"], str):
                args.extend(["--entrypoint", svc["entrypoint"]])

        # Devices (Rn mode only)
        if svc["devices"] and EXEC_MODE.startswith("R"):
            for dev in svc["devices"]:
                args.extend(["--device", dev])

        # Extra arguments
        if extra_args:
            args.extend(extra_args)

        return args

    def start(self, service_name, detach=True):
        """Start a service"""
        svc = self.config.services[service_name]
        container_name = svc["container_name"]

        # Check if already running
        pid = self.state.get_pid(service_name)
        if pid:
            log_info(f"Service '{service_name}' is already running (PID: {pid})")
            return True

        # Build command
        run_args = self._build_run_args(service_name)
        cmd_parts = [UDOCKER_BIN, "run"] + run_args + [container_name]

        # Append command
        command = svc["command"]
        if command:
            if isinstance(command, list):
                cmd_parts.extend(command)
            else:
                cmd_parts.extend(command.split())

        log_info(f"Starting service: {service_name} (container: {container_name})")
        log_debug(f"Command: {' '.join(cmd_parts)}")

        if detach:
            log_path = self.state.get_log_path(service_name)
            log_file = open(log_path, "a")
            log_file.write(f"\n{'='*60}\n")
            log_file.write(f"=== {service_name} started at {time.strftime('%Y-%m-%d %H:%M:%S')} ===\n")
            log_file.write(f"{'='*60}\n")
            log_file.flush()

            proc = subprocess.Popen(
                cmd_parts,
                stdout=log_file,
                stderr=subprocess.STDOUT,
                preexec_fn=os.setpgrp,
            )
            self.state.save_pid(service_name, proc.pid)
            self.state.set_service_state(service_name, pid=proc.pid, status="running")
            log_info(f"  -> PID: {proc.pid}, log: {log_path}")
            return True
        else:
            # Foreground mode
            try:
                r = subprocess.run(cmd_parts)
                return r.returncode == 0
            except KeyboardInterrupt:
                return False

    def stop(self, service_name, timeout=10):
        """Stop a service"""
        pid = self.state.get_pid(service_name)
        if not pid:
            log_info(f"Service '{service_name}' is not running")
            return True

        log_info(f"Stopping service: {service_name} (PID: {pid})")
        try:
            # Send SIGTERM first
            os.killpg(os.getpgid(pid), signal.SIGTERM)
            # Wait for exit
            for _ in range(timeout * 10):
                try:
                    os.kill(pid, 0)
                    time.sleep(0.1)
                except ProcessLookupError:
                    break
            else:
                # Timeout, force kill
                log_warn(f"Service '{service_name}' did not respond to SIGTERM, sending SIGKILL")
                try:
                    os.killpg(os.getpgid(pid), signal.SIGKILL)
                except (ProcessLookupError, PermissionError):
                    pass
        except (ProcessLookupError, PermissionError):
            pass

        self.state.clear_pid(service_name)
        self.state.set_service_state(service_name, pid=None, status="stopped")
        return True

    def remove(self, service_name):
        """Remove a container"""
        svc = self.config.services[service_name]
        container_name = svc["container_name"]
        self.stop(service_name)
        log_info(f"Removing container: {container_name}")
        udocker("rm", "-f", container_name, check=False)
        self.state.remove_service_state(service_name)

    def is_running(self, service_name):
        return self.state.get_pid(service_name) is not None

    def get_status(self, service_name):
        pid = self.state.get_pid(service_name)
        if pid:
            return f"running (PID: {pid})"
        svc_state = self.state.get_service_state(service_name)
        if svc_state.get("created"):
            return "stopped"
        return "not created"

    def check_health(self, service_name, timeout=60):
        """Execute a health check"""
        svc = self.config.services[service_name]
        hc = svc.get("healthcheck")
        if not hc or hc.get("disable"):
            return True

        test = hc.get("test")
        if not test:
            return True

        interval = self._parse_duration(hc.get("interval", "30s"))
        hc_timeout = self._parse_duration(hc.get("timeout", "10s"))
        retries = hc.get("retries", 3)
        start_period = self._parse_duration(hc.get("start_period", "0s"))

        container_name = svc["container_name"]

        # Wait for start_period
        if start_period > 0:
            log_debug(f"Health check: waiting for start period {start_period}s")
            time.sleep(start_period)

        # Build the check command
        if isinstance(test, list):
            if test[0] == "CMD-SHELL":
                check_cmd = test[1]
            elif test[0] == "CMD":
                check_cmd = " ".join(test[1:])
            else:
                check_cmd = " ".join(test)
        else:
            check_cmd = test

        for attempt in range(1, retries + 1):
            log_debug(f"Health check {service_name}: attempt {attempt}/{retries}")
            r = run_cmd(
                [UDOCKER_BIN, "run", container_name, "sh", "-c", check_cmd],
                check=False, capture=True,
            )
            if r.returncode == 0:
                log_info(f"Health check passed: {service_name}")
                return True
            if attempt < retries:
                time.sleep(interval)

        log_warn(f"Health check failed: {service_name} (after {retries} retries)")
        return False

    @staticmethod
    def _parse_duration(s):
        """Parse a Docker duration string (10s, 1m, 500ms)"""
        if isinstance(s, (int, float)):
            return float(s)
        s = str(s).strip()
        if s.endswith("ms"):
            return float(s[:-2]) / 1000
        elif s.endswith("s"):
            return float(s[:-1])
        elif s.endswith("m"):
            return float(s[:-1]) * 60
        elif s.endswith("h"):
            return float(s[:-1]) * 3600
        return float(s)


# ---------------------------------------------------------------------------
# Automatic restart supervisor
# ---------------------------------------------------------------------------

class RestartSupervisor:
    """Monitor service processes and auto-restart according to restart policy"""

    def __init__(self, svc_manager: ServiceManager, config: ComposeConfig, state: StateManager):
        self.svc_manager = svc_manager
        self.config = config
        self.state = state
        self._running = False

    def start(self):
        """Monitor and restart services in a background thread"""
        self._running = True
        import threading
        self._thread = threading.Thread(target=self._loop, daemon=True)
        self._thread.start()

    def stop(self):
        self._running = False

    def _loop(self):
        while self._running:
            time.sleep(5)
            for name, svc in self.config.services.items():
                policy = svc["restart"]
                if policy in ("no", "never"):
                    continue

                pid = self.state.get_pid(name)
                if pid is None:
                    svc_state = self.state.get_service_state(name)
                    if svc_state.get("status") == "running":
                        # Process has exited but status is still running — needs restart
                        if policy in ("always", "unless-stopped"):
                            log_info(f"Auto-restarting: {name}")
                            self.svc_manager.start(name, detach=True)


# ---------------------------------------------------------------------------
# Main orchestrator
# ---------------------------------------------------------------------------

class UdockerCompose:
    """Main entry point: parse commands and execute orchestration"""

    def __init__(self, compose_file=None, project_name=None):
        if compose_file:
            self.compose_file = Path(compose_file)
        else:
            self.compose_file = find_compose_file()
            if not self.compose_file:
                log_error(f"Compose file not found. Supported filenames: {', '.join(COMPOSE_FILES)}")
                sys.exit(1)

        self.config = ComposeConfig(self.compose_file, project_name)
        self.state = StateManager(self.config.project_dir, self.config.project_name)
        self.network = NetworkManager(self.state, self.config)
        self.volumes = VolumeManager(self.state, self.config)
        self.svc_mgr = ServiceManager(self.config, self.state, self.network, self.volumes)
        self.supervisor = RestartSupervisor(self.svc_mgr, self.config, self.state)

    def _filter_services(self, names):
        """Filter by specified service names, or return all if none specified"""
        if not names:
            return self.config.get_startup_order()
        for n in names:
            if n not in self.config.services:
                log_error(f"Unknown service: '{n}'")
                log_info(f"Available services: {', '.join(self.config.get_service_names())}")
                sys.exit(1)
        return names

    def cmd_up(self, services=None, detach=False, no_recreate=False):
        """Start services (equivalent to docker-compose up)"""
        self.state.init()

        # Generate hosts file (networking)
        self.network.generate_hosts_file()

        # Create named volumes
        self.volumes.ensure_volumes()

        order = self.config.get_startup_order()
        targets = self._filter_services(services)
        # Filter by topological order
        order = [s for s in order if s in targets]

        # Also include dependent services
        all_needed = set()
        def collect_deps(name):
            all_needed.add(name)
            for dep in self.config.services[name]["depends_on"]:
                collect_deps(dep)
        for s in targets:
            collect_deps(s)

        order = [s for s in self.config.get_startup_order() if s in all_needed]

        log_info(f"Startup order: {' -> '.join(order)}")
        print()

        for name in order:
            # Pull image (if not available locally)
            svc = self.config.services[name]
            if svc["build"]:
                log_warn(f"Service '{name}' uses build directive — udocker does not support building.")
                log_warn(f"  Please build the image on a machine with Docker and docker save, then import with udocker load.")
                if not svc["image"]:
                    continue

            # Create container
            force = not no_recreate
            self.svc_mgr.create(name, force=force)

            # Inject hosts into container (double assurance)
            self.network.inject_hosts_to_container(svc["container_name"])

            # Start
            self.svc_mgr.start(name, detach=detach or len(order) > 1)

            # Wait briefly for service to start
            time.sleep(1)

            print()

        if detach or len(order) > 1:
            # Start automatic restart monitor
            self.supervisor.start()

            # Print summary
            print()
            self._print_status_table(order)
            print()

            # Print access info
            for name in order:
                svc = self.config.services[name]
                for port in svc["ports"]:
                    log_info(f"  {name}: http://localhost:{port['host']}")

            if not detach:
                # Foreground mode — wait for all processes
                log_info("Press Ctrl+C to stop all services")
                try:
                    while True:
                        time.sleep(1)
                except KeyboardInterrupt:
                    print()
                    self.cmd_down()
        else:
            if not detach:
                # Single service foreground mode
                self.svc_mgr.start(order[0], detach=False)

    def cmd_down(self, remove_volumes=False, services=None):
        """Stop and remove all services"""
        self.supervisor.stop()
        order = self.config.get_startup_order()
        if services:
            order = [s for s in order if s in services]
        # Stop in reverse order
        for name in reversed(order):
            self.svc_mgr.remove(name)

        if remove_volumes:
            log_info("Removing named volumes...")
            for vol_name in self.config.volumes:
                vol_path = self.state.get_volume_path(vol_name)
                if vol_path.exists():
                    import shutil
                    shutil.rmtree(vol_path, ignore_errors=True)
                    log_info(f"  Removed: {vol_name}")

        log_info("All services stopped and cleaned up")

    def cmd_ps(self, services=None):
        """Show service status"""
        names = self._filter_services(services)
        self._print_status_table(names)

    def _print_status_table(self, names):
        """Print status table"""
        header = f"{'SERVICE':<20} {'CONTAINER':<30} {'STATUS':<25} {'PORTS'}"
        print(header)
        print("-" * len(header) + "-" * 20)
        for name in names:
            svc = self.config.services[name]
            status = self.svc_mgr.get_status(name)
            ports = ", ".join(f"{p['host']}->{p['container']}/{p['protocol']}" for p in svc["ports"])
            container = svc["container_name"]
            # Color
            if "running" in status:
                status_colored = f"\033[32m{status}\033[0m"
            elif status == "stopped":
                status_colored = f"\033[33m{status}\033[0m"
            else:
                status_colored = f"\033[90m{status}\033[0m"
            print(f"{name:<20} {container:<30} {status_colored:<35} {ports}")

    def cmd_pull(self, services=None):
        """Pull all images"""
        names = self._filter_services(services)
        for name in names:
            self.svc_mgr.pull(name)

    def cmd_logs(self, services=None, follow=False, tail=50):
        """View logs"""
        self.state.init()
        names = self._filter_services(services)

        if follow:
            # Follow multiple log files with tail -f
            log_files = []
            for name in names:
                log_path = self.state.get_log_path(name)
                if log_path.exists():
                    log_files.append(str(log_path))
            if not log_files:
                log_warn("No log files found")
                return
            cmd = ["tail", "-f", "-n", str(tail)] + log_files
            try:
                subprocess.run(cmd)
            except KeyboardInterrupt:
                pass
        else:
            for name in names:
                log_path = self.state.get_log_path(name)
                if log_path.exists():
                    print(f"\033[36m=== {name} ===\033[0m")
                    lines = log_path.read_text().splitlines()
                    for line in lines[-tail:]:
                        print(line)
                    print()
                else:
                    log_warn(f"Service '{name}' has no logs")

    def cmd_restart(self, services=None):
        """Restart services"""
        names = self._filter_services(services)
        for name in names:
            self.svc_mgr.stop(name)
            time.sleep(1)
            self.svc_mgr.start(name, detach=True)

    def cmd_stop(self, services=None):
        """Stop services without removing containers"""
        names = self._filter_services(services)
        for name in reversed(names):
            self.svc_mgr.stop(name)

    def cmd_start(self, services=None):
        """Start stopped services"""
        self.state.init()
        self.network.generate_hosts_file()
        names = self._filter_services(services)
        for name in names:
            svc = self.config.services[name]
            self.network.inject_hosts_to_container(svc["container_name"])
            self.svc_mgr.start(name, detach=True)

    def cmd_exec(self, service_name, command):
        """Execute a command in a service container"""
        if service_name not in self.config.services:
            log_error(f"Unknown service: '{service_name}'")
            sys.exit(1)

        svc = self.config.services[service_name]
        container_name = svc["container_name"]
        run_args = self.svc_mgr._build_run_args(service_name)

        cmd_parts = [UDOCKER_BIN, "run"] + run_args + [container_name] + command
        log_debug(f"exec: {' '.join(cmd_parts)}")
        r = subprocess.run(cmd_parts)
        return r.returncode

    def cmd_run(self, service_name, command, rm=False):
        """Run a one-off command in a service container"""
        if service_name not in self.config.services:
            log_error(f"Unknown service: '{service_name}'")
            sys.exit(1)

        self.state.init()
        self.network.generate_hosts_file()
        self.volumes.ensure_volumes()

        svc = self.config.services[service_name]
        # Create temporary container
        tmp_name = f"{svc['container_name']}_run_{int(time.time())}"
        image = svc["image"]

        udocker("create", f"--name={tmp_name}", image, check=False)
        udocker("setup", f"--execmode={EXEC_MODE}", tmp_name, check=False)
        self.network.inject_hosts_to_container(tmp_name)

        run_args = self.svc_mgr._build_run_args(service_name)
        cmd_parts = [UDOCKER_BIN, "run"] + run_args

        # Use temporary container name
        cmd_parts.append(tmp_name)
        cmd_parts.extend(command)

        try:
            r = subprocess.run(cmd_parts)
            return r.returncode
        finally:
            if rm:
                udocker("rm", "-f", tmp_name, check=False)

    def cmd_config(self):
        """Validate and display configuration"""
        print(f"Project: {self.config.project_name}")
        print(f"Compose file: {self.config.filepath}")
        print(f"Exec mode: {EXEC_MODE}")
        print()

        order = self.config.get_startup_order()
        print(f"Startup order: {' -> '.join(order)}")
        print()

        print("Services:")
        for name in order:
            svc = self.config.services[name]
            print(f"  {name}:")
            print(f"    image: {svc['image']}")
            print(f"    container: {svc['container_name']}")
            if svc["build"]:
                print(f"    build: {svc['build']} (not supported by udocker)")
            if svc["ports"]:
                ports = ", ".join(f"{p['host']}:{p['container']}" for p in svc["ports"])
                print(f"    ports: {ports}")
            if svc["volumes"]:
                for v in svc["volumes"]:
                    src = v["host"] or "(anonymous)"
                    print(f"    volume: {src} -> {v['container']}")
            if svc["depends_on"]:
                print(f"    depends_on: {', '.join(svc['depends_on'])}")
            if svc["environment"]:
                print(f"    env: {len(svc['environment'])} vars")
            print(f"    restart: {svc['restart']}")
            print()

        print("Networks:")
        if self.config.networks:
            for net in self.config.networks:
                print(f"  {net} -> host network (/etc/hosts name mapping)")
        else:
            print("  default -> host network (/etc/hosts name mapping)")
        print()

        if self.config.volumes:
            print("Named volumes:")
            for vol in self.config.volumes:
                print(f"  {vol} -> {self.state.get_volume_path(vol)}")
            print()


# ---------------------------------------------------------------------------
# CLI Entry Point
# ---------------------------------------------------------------------------

def build_parser():
    parser = argparse.ArgumentParser(
        prog="udocker-compose",
        description="Docker Compose compatible orchestration tool for udocker",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Environment variables:
              UDOCKER_COMPOSE_UDOCKER   Path to udocker binary (default: udocker)
              UDOCKER_COMPOSE_EXECMODE  Execution mode (default: P1, options: P1,P2,F1-F4,R1-R3,S1)
              UDOCKER_COMPOSE_DEBUG     Set to 1 for debug output

            Examples:
              udocker-compose up -d                     # Start all services in background
              udocker-compose up redis postgres          # Start specific services only
              udocker-compose down -v                    # Stop and remove volumes
              udocker-compose logs -f new-api            # Follow logs
              udocker-compose exec new-api sh            # Execute shell in container
              udocker-compose config                     # Show parsed configuration

            Limitations:
              - No docker build support (use save/load for images)
              - No network isolation (all services share host network)
              - Port mapping only works in Pn modes
              - Cannot bind ports < 1024
        """),
    )

    parser.add_argument("-f", "--file", help="Compose file path")
    parser.add_argument("-p", "--project-name", help="Project name")

    sub = parser.add_subparsers(dest="command", help="Subcommands")

    # up
    p_up = sub.add_parser("up", help="Create and start services")
    p_up.add_argument("-d", "--detach", action="store_true", help="Run in background")
    p_up.add_argument("--no-recreate", action="store_true", help="Do not recreate existing containers")
    p_up.add_argument("services", nargs="*", help="Service names")

    # down
    p_down = sub.add_parser("down", help="Stop and remove services")
    p_down.add_argument("-v", "--volumes", action="store_true", help="Also remove named volumes")
    p_down.add_argument("services", nargs="*", help="Service names")

    # ps
    p_ps = sub.add_parser("ps", help="List service status")
    p_ps.add_argument("services", nargs="*")

    # pull
    p_pull = sub.add_parser("pull", help="Pull images")
    p_pull.add_argument("services", nargs="*")

    # logs
    p_logs = sub.add_parser("logs", help="View logs")
    p_logs.add_argument("-f", "--follow", action="store_true", help="Follow log output")
    p_logs.add_argument("-n", "--tail", type=int, default=50, help="Number of lines to show")
    p_logs.add_argument("services", nargs="*")

    # restart
    p_restart = sub.add_parser("restart", help="Restart services")
    p_restart.add_argument("services", nargs="*")

    # stop
    p_stop = sub.add_parser("stop", help="Stop services")
    p_stop.add_argument("services", nargs="*")

    # start
    p_start = sub.add_parser("start", help="Start stopped services")
    p_start.add_argument("services", nargs="*")

    # exec
    p_exec = sub.add_parser("exec", help="Execute command in container")
    p_exec.add_argument("service", help="Service name")
    p_exec.add_argument("exec_command", nargs=argparse.REMAINDER, help="Command to execute")

    # run
    p_run = sub.add_parser("run", help="Run a one-off command")
    p_run.add_argument("--rm", action="store_true", help="Remove container after exit")
    p_run.add_argument("service", help="Service name")
    p_run.add_argument("run_command", nargs=argparse.REMAINDER, help="Command to run")

    # config
    sub.add_parser("config", help="Show parsed configuration")

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    # Signal handling — don't register SIGINT here, let KeyboardInterrupt propagate
    def sigterm_handler(sig, frame):
        print()
        log_info("Received SIGTERM, shutting down...")
        sys.exit(143)
    signal.signal(signal.SIGTERM, sigterm_handler)

    try:
        uc = UdockerCompose(compose_file=args.file, project_name=args.project_name)
    except FileNotFoundError as e:
        log_error(str(e))
        sys.exit(1)
    except ValueError as e:
        log_error(f"Config error: {e}")
        sys.exit(1)

    cmd = args.command

    if cmd == "up":
        uc.cmd_up(services=args.services or None,
                   detach=args.detach,
                   no_recreate=args.no_recreate)
    elif cmd == "down":
        uc.cmd_down(remove_volumes=args.volumes,
                    services=args.services or None)
    elif cmd == "ps":
        uc.cmd_ps(services=args.services or None)
    elif cmd == "pull":
        uc.cmd_pull(services=args.services or None)
    elif cmd == "logs":
        uc.cmd_logs(services=args.services or None,
                    follow=args.follow, tail=args.tail)
    elif cmd == "restart":
        uc.cmd_restart(services=args.services or None)
    elif cmd == "stop":
        uc.cmd_stop(services=args.services or None)
    elif cmd == "start":
        uc.cmd_start(services=args.services or None)
    elif cmd == "exec":
        code = uc.cmd_exec(args.service, args.exec_command)
        sys.exit(code)
    elif cmd == "run":
        code = uc.cmd_run(args.service, args.run_command, rm=args.rm)
        sys.exit(code)
    elif cmd == "config":
        uc.cmd_config()
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
