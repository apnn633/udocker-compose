#!/usr/bin/env python3
"""udocker-compose — Docker Compose 兼容的 udocker 编排工具

功能:
  - 解析 docker-compose.yml (v2/v3)
  - 服务依赖拓扑排序与按序启动
  - 模拟 Docker 网络 (通过 /etc/hosts 注入实现服务名解析)
  - 命名卷管理 (映射为本地目录)
  - 进程生命周期管理与自动重启
  - 健康检查
  - 日志管理

用法:
  udocker-compose up [-d] [--no-recreate] [service...]
  udocker-compose down [-v]
  udocker-compose ps
  udocker-compose pull [service...]
  udocker-compose logs [-f] [-n N] [service...]
  udocker-compose restart [service...]
  udocker-compose stop [service...]
  udocker-compose start [service...]
  udocker-compose exec service command [args...]
  udocker-compose config
  udocker-compose run [--rm] service command [args...]
"""

import argparse
import hashlib
import json
import os
import signal
import subprocess
import sys
import textwrap
import time
from collections import defaultdict
from pathlib import Path

try:
    import yaml
except ImportError:
    print("错误: 需要 PyYAML。请运行: pip install pyyaml", file=sys.stderr)
    sys.exit(1)

# ---------------------------------------------------------------------------
# 常量
# ---------------------------------------------------------------------------
COMPOSE_FILES = ["docker-compose.yml", "docker-compose.yaml", "compose.yml", "compose.yaml"]
STATE_DIR_NAME = ".udocker-compose"
UDOCKER_BIN = os.environ.get("UDOCKER_COMPOSE_UDOCKER", "udocker")
EXEC_MODE = os.environ.get("UDOCKER_COMPOSE_EXECMODE", "P1")

# ---------------------------------------------------------------------------
# 工具函数
# ---------------------------------------------------------------------------

def log_info(msg):
    print(f"\033[32m[+]\033[0m {msg}")

def log_warn(msg):
    print(f"\033[33m[!]\033[0m {msg}", file=sys.stderr)

def log_error(msg):
    print(f"\033[31m[-]\033[0m {msg}", file=sys.stderr)

def log_debug(msg):
    if os.environ.get("UDOCKER_COMPOSE_DEBUG"):
        print(f"\033[36m[D]\033[0m {msg}", file=sys.stderr)

def run_cmd(cmd, check=True, capture=False, **kwargs):
    """执行 shell 命令"""
    log_debug(f"exec: {cmd if isinstance(cmd, str) else ' '.join(cmd)}")
    stdout = subprocess.PIPE if capture else None
    stderr = subprocess.PIPE if capture else None
    r = subprocess.run(cmd, shell=isinstance(cmd, str), check=check,
                       stdout=stdout, stderr=stderr, text=True, **kwargs)
    return r

def udocker(*args, check=True, capture=False):
    """调用 udocker 命令"""
    cmd = [UDOCKER_BIN] + list(args)
    return run_cmd(cmd, check=check, capture=capture)

def find_compose_file(directory="."):
    """查找 compose 文件"""
    for name in COMPOSE_FILES:
        p = Path(directory) / name
        if p.exists():
            return p
    return None

# ---------------------------------------------------------------------------
# YAML 解析与规范化
# ---------------------------------------------------------------------------

class ComposeConfig:
    """解析并规范化 docker-compose.yml"""

    def __init__(self, filepath, project_name=None):
        self.filepath = Path(filepath).resolve()
        self.project_dir = self.filepath.parent
        self.project_name = project_name or self.project_dir.name
        # 规范化项目名：只保留字母数字和连字符
        self.project_name = "".join(
            c if c.isalnum() or c in "-_" else "" for c in self.project_name
        ).lower()

        with open(self.filepath) as f:
            self.raw = yaml.safe_load(f)

        self.services = {}
        self.networks = {}
        self.volumes = {}
        self._parse()

    def _parse(self):
        raw_services = self.raw.get("services", {})
        if not raw_services:
            raise ValueError("compose 文件中没有找到 services 定义")

        self.networks = self.raw.get("networks", {})
        self.volumes = self.raw.get("volumes", {})

        for name, svc_def in raw_services.items():
            self.services[name] = self._normalize_service(name, svc_def)

    def _normalize_service(self, name, svc):
        """将 compose 服务定义规范化为内部格式"""
        normalized = {
            "name": name,
            "container_name": svc.get("container_name", f"{self.project_name}_{name}"),
            "image": svc.get("image"),
            "build": svc.get("build"),
            "command": self._normalize_command(svc.get("command")),
            "entrypoint": self._normalize_command(svc.get("entrypoint")),
            "environment": self._normalize_env(svc.get("environment")),
            "env_file": self._normalize_list(svc.get("env_file")),
            "volumes": self._normalize_volumes(svc.get("volumes", [])),
            "ports": self._normalize_ports(svc.get("ports", [])),
            "depends_on": self._normalize_depends(svc.get("depends_on")),
            "networks": self._normalize_list(svc.get("networks")) or list(self.networks.keys()) or ["default"],
            "restart": svc.get("restart", "no"),
            "user": svc.get("user"),
            "working_dir": svc.get("working_dir"),
            "hostname": svc.get("hostname", name),
            "healthcheck": svc.get("healthcheck"),
            "shm_size": svc.get("shm_size"),
            "extra_hosts": self._normalize_list(svc.get("extra_hosts")),
            "dns": self._normalize_list(svc.get("dns")),
            "tmpfs": self._normalize_list(svc.get("tmpfs")),
            "privileged": svc.get("privileged", False),
            "devices": self._normalize_list(svc.get("devices")),
            "cap_add": self._normalize_list(svc.get("cap_add")),
        }

        # 如果没有 image 也没有 build，报错
        if not normalized["image"] and not normalized["build"]:
            raise ValueError(f"服务 '{name}' 必须指定 image 或 build")

        # 如果有 build 但没有 image，生成一个镜像名
        if normalized["build"] and not normalized["image"]:
            normalized["image"] = f"{self.project_name}_{name}:latest"

        return normalized

    def _normalize_command(self, cmd):
        if cmd is None:
            return None
        if isinstance(cmd, list):
            return cmd
        return cmd  # 字符串形式，保持原样

    def _normalize_env(self, env):
        """统一环境变量为 dict"""
        if env is None:
            return {}
        if isinstance(env, dict):
            return {k: str(v) for k, v in env.items()}
        if isinstance(env, list):
            result = {}
            for item in env:
                if "=" in item:
                    k, v = item.split("=", 1)
                    result[k] = v
                else:
                    result[item] = os.environ.get(item, "")
            return result
        return {}

    def _normalize_list(self, val):
        if val is None:
            return []
        if isinstance(val, str):
            return [val]
        return list(val)

    def _normalize_volumes(self, vols):
        """规范化 volumes 为 [{host, container, mode}] 列表"""
        result = []
        for v in vols:
            if isinstance(v, str):
                parts = v.split(":")
                if len(parts) == 1:
                    result.append({"host": None, "container": parts[0], "mode": "rw"})
                elif len(parts) == 2:
                    result.append({"host": parts[0], "container": parts[1], "mode": "rw"})
                else:
                    result.append({"host": parts[0], "container": parts[1], "mode": parts[2]})
            elif isinstance(v, dict):
                result.append({
                    "host": v.get("source"),
                    "container": v.get("target"),
                    "mode": "ro" if v.get("read_only") else "rw",
                })
        return result

    def _normalize_ports(self, ports):
        """规范化端口映射为 [{host_port, container_port, protocol}]"""
        result = []
        for p in ports:
            if isinstance(p, (int, float)):
                result.append({"host": str(int(p)), "container": str(int(p)), "protocol": "tcp"})
            elif isinstance(p, str):
                # "8000:8000", "8000:8000/udp", "127.0.0.1:8000:8000"
                proto = "tcp"
                if "/" in p:
                    p, proto = p.rsplit("/", 1)
                parts = p.split(":")
                if len(parts) == 1:
                    result.append({"host": parts[0], "container": parts[0], "protocol": proto})
                elif len(parts) == 2:
                    result.append({"host": parts[0], "container": parts[1], "protocol": proto})
                elif len(parts) == 3:
                    # host_ip:host_port:container_port — 忽略 host_ip
                    result.append({"host": parts[1], "container": parts[2], "protocol": proto})
            elif isinstance(p, dict):
                result.append({
                    "host": str(p.get("published", p.get("target"))),
                    "container": str(p.get("target")),
                    "protocol": p.get("protocol", "tcp"),
                })
        return result

    def _normalize_depends(self, deps):
        """规范化 depends_on"""
        if deps is None:
            return []
        if isinstance(deps, list):
            return deps
        if isinstance(deps, dict):
            # v2/v3 with condition
            return list(deps.keys())
        return []

    def get_service_names(self):
        return list(self.services.keys())

    def get_startup_order(self):
        """拓扑排序，返回按依赖顺序排列的服务名列表"""
        graph = defaultdict(set)
        in_degree = defaultdict(int)
        all_services = set(self.services.keys())

        for name, svc in self.services.items():
            in_degree.setdefault(name, 0)
            for dep in svc["depends_on"]:
                if dep not in all_services:
                    raise ValueError(f"服务 '{name}' 依赖不存在的服务 '{dep}'")
                graph[dep].add(name)
                in_degree[name] += 1

        queue = [s for s in all_services if in_degree[s] == 0]
        order = []
        while queue:
            queue.sort()  # 稳定排序
            node = queue.pop(0)
            order.append(node)
            for neighbor in sorted(graph[node]):
                in_degree[neighbor] -= 1
                if in_degree[neighbor] == 0:
                    queue.append(neighbor)

        if len(order) != len(all_services):
            raise ValueError("检测到循环依赖！")

        return order


# ---------------------------------------------------------------------------
# 状态管理
# ---------------------------------------------------------------------------

class StateManager:
    """管理 .udocker-compose/ 目录下的运行状态"""

    def __init__(self, project_dir, project_name):
        self.base = Path(project_dir) / STATE_DIR_NAME
        self.project_name = project_name
        self.pids_dir = self.base / "pids"
        self.logs_dir = self.base / "logs"
        self.volumes_dir = self.base / "volumes"
        self.network_dir = self.base / "network"
        self.state_file = self.base / "state.json"

    def init(self):
        """创建目录结构"""
        for d in [self.pids_dir, self.logs_dir, self.volumes_dir, self.network_dir]:
            d.mkdir(parents=True, exist_ok=True)
        if not self.state_file.exists():
            self._save_state({})

    def _load_state(self):
        try:
            return json.loads(self.state_file.read_text())
        except (json.JSONDecodeError, FileNotFoundError):
            return {}

    def _save_state(self, state):
        self.state_file.write_text(json.dumps(state, indent=2, ensure_ascii=False))

    def set_service_state(self, name, **kwargs):
        state = self._load_state()
        if name not in state:
            state[name] = {}
        state[name].update(kwargs)
        self._save_state(state)

    def get_service_state(self, name):
        return self._load_state().get(name, {})

    def remove_service_state(self, name):
        state = self._load_state()
        state.pop(name, None)
        self._save_state(state)

    def get_all_states(self):
        return self._load_state()

    def save_pid(self, service_name, pid):
        (self.pids_dir / f"{service_name}.pid").write_text(str(pid))

    def get_pid(self, service_name):
        pidfile = self.pids_dir / f"{service_name}.pid"
        if pidfile.exists():
            try:
                pid = int(pidfile.read_text().strip())
                # 检查进程是否存活
                os.kill(pid, 0)
                return pid
            except (ValueError, ProcessLookupError, PermissionError):
                pidfile.unlink(missing_ok=True)
        return None

    def clear_pid(self, service_name):
        (self.pids_dir / f"{service_name}.pid").unlink(missing_ok=True)

    def get_log_path(self, service_name):
        return self.logs_dir / f"{service_name}.log"

    def get_volume_path(self, volume_name):
        return self.volumes_dir / volume_name

    def get_hosts_file(self):
        return self.network_dir / "hosts"


# ---------------------------------------------------------------------------
# 网络管理 — 模拟 Docker 网络
# ---------------------------------------------------------------------------

class NetworkManager:
    """通过 /etc/hosts 注入和 bind mount 模拟 Docker 网络

    原理:
      Docker 中同一 network 下的容器可通过服务名互相访问。
      udocker 所有容器共享宿主机网络栈，因此:
      1. 生成一个 hosts 文件，将所有服务名映射到 127.0.0.1
      2. 通过 -v 将该 hosts 文件挂载到每个容器的 /etc/hosts
      3. 服务间通过 localhost + 各自端口通信
    """

    def __init__(self, state: StateManager, config: ComposeConfig):
        self.state = state
        self.config = config

    def generate_hosts_file(self):
        """生成包含所有服务名映射的 /etc/hosts 文件"""
        hosts_path = self.state.get_hosts_file()
        lines = [
            "# Generated by udocker-compose — 模拟 Docker 网络",
            "127.0.0.1\tlocalhost",
            "::1\tlocalhost ip6-localhost ip6-loopback",
        ]

        # 为每个服务添加 hostname 和服务名映射
        service_names = set()
        for name, svc in self.config.services.items():
            service_names.add(name)
            service_names.add(svc["container_name"])
            service_names.add(svc["hostname"])

        # 所有服务名 -> 127.0.0.1
        names_str = "\t".join(sorted(service_names))
        lines.append(f"127.0.0.1\t{names_str}")

        # 添加 extra_hosts
        for name, svc in self.config.services.items():
            for host_entry in svc.get("extra_hosts", []):
                if ":" in host_entry:
                    hostname, ip = host_entry.split(":", 1)
                    lines.append(f"{ip.strip()}\t{hostname.strip()}")

        hosts_path.write_text("\n".join(lines) + "\n")
        log_info(f"网络: 已生成 hosts 文件 ({len(service_names)} 个服务名)")
        return hosts_path

    def inject_hosts_to_container(self, container_name):
        """获取容器 rootfs 路径并复制 hosts 文件（备用方案，当 -v 挂载不可靠时）"""
        try:
            r = udocker("inspect", "-p", container_name, capture=True, check=False)
            if r.returncode == 0 and r.stdout.strip():
                rootfs = Path(r.stdout.strip())
                etc_hosts = rootfs / "etc" / "hosts"
                if etc_hosts.parent.exists():
                    hosts_content = self.state.get_hosts_file().read_text()
                    etc_hosts.write_text(hosts_content)
                    log_debug(f"已注入 hosts 到 {etc_hosts}")
                    return True
        except Exception as e:
            log_debug(f"hosts 注入失败: {e}")
        return False

    def get_run_args(self):
        """返回用于 udocker run 的网络相关参数"""
        hosts_path = self.state.get_hosts_file()
        if hosts_path.exists():
            return ["-v", f"{hosts_path}:/etc/hosts"]
        return []


